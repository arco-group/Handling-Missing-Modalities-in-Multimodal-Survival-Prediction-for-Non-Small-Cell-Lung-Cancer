    // , visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "LATE FUSION-CT-TAB",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.AIDA_MM/bin/python",
            "args": [
                "experiment=late_AIDA_multimodal_CT+tabular_Cixregression_cox_label_.yaml"
            ]
        },
        {
            "name": "LATE FUSION-WSI-TAb",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.AIDA_MM/bin/python",
            "args": [
                "experiment=late_AIDA_multimodal_WSI+tabular_Cixregression_cox_label.yaml"
            ]
        },
        {
            "name": "LATE FUSION-WSI-TAb-CT",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.AIDA_MM/bin/python",
            "args": [
                "experiment=late_AIDA_multimodal_WSI+CT+tabular_Cixregression_cox_label.yaml"
            ]
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "python": "${workspaceFolder}/.AIDA_MM/bin/python",
            "console": "integratedTerminal"
        },
        {
            "name": "Run Multimodal AIDA Experiment",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "args": [
                "experiment=AIDA_multimodal_WSI+CT_${input:task}_cox_label",
                "experiment/model@shared_net=${input:model}",
                "continue_experiment=true",
                "mode=wsi_ct_cox-label_cix",
                "experiment/databases@dbs.0=WSI_AIDA_${input:target}",
                "experiment/databases@dbs.1=CT_AIDA_${input:target}",
                //"experiment/databases@dbs.2=AIDA_${input:target}",
                "db_name=WSI+CT_multimodal_${input:target}"
            ],
            "python": "${workspaceFolder}/.AIDA_MM/bin/python",
            "justMyCode": false
        }
    ],
}