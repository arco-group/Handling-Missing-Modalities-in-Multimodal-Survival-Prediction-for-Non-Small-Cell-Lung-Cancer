{
    // Python interpreter: the project venv
    "python.defaultInterpreterPath": "${workspaceFolder}/.ditunet_venv/bin/python",
    "python.analysis.extraPaths": ["${workspaceFolder}"],

    // Every new integrated terminal sources terminal_init.sh,
    // which loads the module and activates the venv automatically.
    "terminal.integrated.profiles.linux": {
        "bash (ditunet)": {
            "path": "bash",
            "args": ["--init-file", "${workspaceFolder}/scripts/terminal_init.sh"]
        }
    },
    "terminal.integrated.defaultProfile.linux": "bash (ditunet)"
}
